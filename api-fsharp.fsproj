<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>CriticalPathExtractor</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Domain.fs" />
    <Compile Include="Infrastructure\Localization.fs" />
    <Compile Include="Infrastructure\ThresholdValueConverter.fs" />
    <Compile Include="Infrastructure\RequestSizeLimit.fs" />
    <Compile Include="CpmEngine.fs" />
    <Compile Include="Controllers\CriticalPathController.fs" />
    <Compile Include="Program.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="10.0.3" />
    <PackageReference Include="Scalar.AspNetCore" Version="2.12.50" />
  </ItemGroup>

</Project>
